{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "ossigeno/ssnail-tabs",
    "allowedBlocks": [
        "ossigeno/ssnail-tab"
    ],
    "title": "SSnail Tabs",
    "category": "snappysnail",
    "icon": "table-row-after",
    "description": "Add tabbed panels to your website.",
    "keywords": [
        "tabs",
        "tabbed panels",
        "tabbed content"
    ],
    "version": "1.0.0",
    "textdomain": "ossigeno",
    "attributes": {
        "tabLabels": {
            "type": "array",
            "default": [
                "Tab 1"
            ]
        },
        "currentTabIndex": {
            "type": "number",
            "default": 0
        }
    },
    "providesContext": {
        "ssnail-tabs/currentTabIndex": "currentTabIndex"
    },
    "selectors": {
        "root": ".ssnail-tabs"
    },
    "editorStyle": "file:./index.css",
    "editorScript": "file:./index.js",
    "viewScript": "file:./view.js",
    "render": "file:./render.php"
}